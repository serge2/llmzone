{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",

    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*:*" },
        { "url": "https://*:*" }
      ],
      "deny": []
    },
    "fs:scope-app-recursive",
    "fs:scope-appconfig-recursive",
    "fs:allow-app-meta-recursive",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",

    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "node", "cmd": "node", "args": true },
        { "name": "python", "cmd": "python", "args": true },
        { "name": "python3", "cmd": "python3", "args": true },
        { "name": "npx", "cmd": "npx", "args": true },
        { "name": "uvx", "cmd": "uvx", "args": true }
      ]
    }
  ]
}
